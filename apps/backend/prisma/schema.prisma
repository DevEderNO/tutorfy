// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String?
  googleId  String?  @unique @map("google_id")
  name      String
  avatarUrl             String?          @map("avatar_url")
  evolutionAiMode       EvolutionAiMode  @default(AUTO) @map("evolution_ai_mode")
  lessonPlanAiMode      LessonPlanAiMode @default(OFF)  @map("lesson_plan_ai_mode")
  lessonPlanFields      String[]         @default([])   @map("lesson_plan_fields")
  lessonPlanSessionCount Int             @default(3)    @map("lesson_plan_session_count")
  isActive              Boolean          @default(true) @map("is_active")
  createdAt             DateTime         @default(now()) @map("created_at")

  students     Student[]
  classSessions ClassSession[]
  payments     Payment[]
  passwordResetTokens PasswordResetToken[]
  skillCategories     SkillCategory[]
  subscription        Subscription?
  guardians           Guardian[]
  studentFiles        StudentFile[]

  @@map("users")
}

model Guardian {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  name         String
  phone        String?
  email        String?
  cpf          String?
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentLinks  GuardianStudent[]

  @@index([userId])
  @@map("guardians")
}

model GuardianStudent {
  id           String   @id @default(uuid())
  guardianId   String   @map("guardian_id")
  studentId    String   @map("student_id")
  relationship String?
  createdAt    DateTime @default(now()) @map("created_at")

  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([guardianId, studentId])
  @@index([guardianId])
  @@index([studentId])
  @@map("guardian_students")
}

model Student {
  id               String      @id @default(uuid())
  userId           String      @map("user_id")
  name             String
  avatarUrl        String?     @map("avatar_url")
  grade            String
  school           String
  responsibleName  String?     @map("responsible_name")
  responsiblePhone String?     @map("responsible_phone")
  billingType      BillingType @default(MONTHLY) @map("billing_type")
  monthlyFee       Float       @default(0) @map("monthly_fee")
  hourlyRate       Float?      @map("hourly_rate")
  active           Boolean     @default(true)
  cpf              String?
  email            String?
  birthDate        DateTime?   @map("birth_date")
  shift            String?
  dueDate          String?     @map("due_date")
  createdAt        DateTime    @default(now()) @map("created_at")

  // Avaliação Inicial
  currentLevel        String?  @map("current_level")
  strengths           String?
  areasToImprove      String?  @map("areas_to_improve")
  goals               String?
  initialObservations String?  @map("initial_observations")

  user          User           @relation(fields: [userId], references: [id])
  classSessions ClassSession[]
  payments      Payment[]
  schedulePreferences StudentSchedulePreference[]
  evolutionEntries    EvolutionEntry[]
  shareToken    StudentShareToken?
  guardianLinks GuardianStudentLink[]
  studentLink   StudentPortalLink?
  guardians     GuardianStudent[]
  files         StudentFile[]

  @@index([userId])
  @@map("students")
}

model StudentShareToken {
  id        String   @id @default(uuid())
  studentId String   @unique @map("student_id")
  token     String   @unique @default(uuid())
  createdAt DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_share_tokens")
}

enum FileType {
  TAREFA
  MATERIAL
  TRABALHO
  OUTRO
}

enum BillingType {
  MONTHLY
  HOURLY
}

enum EvolutionAiMode {
  AUTO
  REVIEW
}

enum LessonPlanAiMode {
  OFF
  AUTO
  DEMAND
}

enum ClassSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  MISSED
}

model ClassSession {
  id        String             @id @default(uuid())
  userId    String             @map("user_id")
  studentId String             @map("student_id")
  date      DateTime
  startTime String             @map("start_time")
  endTime   String             @map("end_time")
  status    ClassSessionStatus @default(SCHEDULED)
  content   String?
  homework  String?
  notes     String?
  createdAt DateTime           @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  evolutionEntries EvolutionEntry[]
  files            StudentFile[]

  @@index([userId])
  @@index([studentId])
  @@index([date])
  @@map("class_sessions")
}

model StudentFile {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  studentId      String   @map("student_id")
  classSessionId String?  @map("class_session_id")
  type           FileType
  title          String
  url            String
  createdAt      DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId],         references: [id])
  student      Student       @relation(fields: [studentId],      references: [id], onDelete: Cascade)
  classSession ClassSession? @relation(fields: [classSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([studentId])
  @@index([classSessionId])
  @@map("student_files")
}

model Payment {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  studentId   String      @map("student_id")
  month       Int
  year        Int
  amount      Float
  billingType BillingType @default(MONTHLY) @map("billing_type")
  classHours  Float?      @map("class_hours")
  paid        Boolean     @default(false)
  paidAt      DateTime?   @map("paid_at")
  createdAt   DateTime    @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@unique([studentId, month, year])
  @@index([userId])
  @@index([studentId])
  @@map("payments")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

model StudentSchedulePreference {
  id        String   @id @default(uuid())
  studentId String   @map("student_id")
  dayOfWeek Int      @map("day_of_week") // 0-6 (Sunday to Saturday)
  startTime String   @map("start_time") // HH:mm
  endTime   String   @map("end_time")   // HH:mm
  createdAt DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("student_schedule_preferences")
}

model SkillCategory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  color     String?
  createdAt DateTime @default(now()) @map("created_at")

  user    User                   @relation(fields: [userId], references: [id])
  entries EvolutionEntryCategory[]

  @@unique([userId, name])
  @@index([userId])
  @@map("skill_categories")
}

model EvolutionEntry {
  id             String   @id @default(uuid())
  studentId      String   @map("student_id")
  classSessionId String?  @map("class_session_id")
  description    String
  createdAt      DateTime @default(now()) @map("created_at")

  student      Student                @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classSession ClassSession?          @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  categories   EvolutionEntryCategory[]

  @@index([studentId])
  @@index([classSessionId])
  @@map("evolution_entries")
}

model EvolutionEntryCategory {
  entryId    String @map("entry_id")
  categoryId String @map("category_id")

  entry    EvolutionEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  category SkillCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([entryId, categoryId])
  @@map("evolution_entry_categories")
}

// ─── Planos e Assinaturas ────────────────────────────────────────────────────

model Plan {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  maxStudents  Int?     @map("max_students")
  aiEnabled    Boolean  @default(false) @map("ai_enabled")
  priceMonthly Float    @default(0) @map("price_monthly")
  priceAnnual  Float    @default(0) @map("price_annual")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id         String             @id @default(uuid())
  userId     String             @unique @map("user_id")
  planId     String             @map("plan_id")
  period     SubscriptionPeriod
  status     SubscriptionStatus
  startedAt  DateTime           @default(now()) @map("started_at")
  expiresAt  DateTime?          @map("expires_at")
  canceledAt DateTime?          @map("canceled_at")

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@map("subscriptions")
}

enum SubscriptionPeriod {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

// ─── Portal Administrativo ───────────────────────────────────────────────────

model AdminUser {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String
  name        String
  adminRole   AdminRole @map("admin_role")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  lastLoginAt DateTime? @map("last_login_at")

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  SUPPORT
}

// ─── Portal Aluno / Responsável ──────────────────────────────────────────────

model PortalAccount {
  id          String            @id @default(uuid())
  email       String?           @unique
  password    String?
  name        String
  accountType PortalAccountType @map("account_type")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  lastLoginAt DateTime?         @map("last_login_at")

  guardianLinks GuardianStudentLink[]
  studentLink   StudentPortalLink?

  @@map("portal_accounts")
}

enum PortalAccountType {
  STUDENT
  GUARDIAN
}

model GuardianStudentLink {
  id         String   @id @default(uuid())
  guardianId String   @map("guardian_id")
  studentId  String   @map("student_id")
  createdAt  DateTime @default(now()) @map("created_at")

  guardian PortalAccount @relation(fields: [guardianId], references: [id])
  student  Student       @relation(fields: [studentId], references: [id])

  @@unique([guardianId, studentId])
  @@index([guardianId])
  @@index([studentId])
  @@map("guardian_student_links")
}

model StudentPortalLink {
  id              String   @id @default(uuid())
  portalAccountId String   @unique @map("portal_account_id")
  studentId       String   @unique @map("student_id")
  createdAt       DateTime @default(now()) @map("created_at")

  portalAccount PortalAccount @relation(fields: [portalAccountId], references: [id])
  student       Student       @relation(fields: [studentId], references: [id])

  @@map("student_portal_links")
}

// ─── Configurações globais da plataforma ─────────────────────────────────────

model AppSettings {
  id        String   @id @default("singleton")
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
